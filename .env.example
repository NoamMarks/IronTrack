VITE_PUBLIC_URL=https://irontrack.vercel.app
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
RESEND_API_KEY=your_resend_api_key_here

# Web Push (VAPID) — generate once with `npx web-push generate-vapid-keys`.
# Public key is exposed to the client to call PushManager.subscribe; private
# key + subject stay server-side and only feed api/send-notification.
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@irontrack.app