# IronTrack environment variables
#
# Copy this file to `.env` (git-ignored) and fill in the values appropriate
# for your deployment. Only `VITE_*`-prefixed vars are exposed to the bundle.

# Production base URL used by buildInviteLink so generated magic links point
# at the deployed app rather than the local dev server. When unset, the app
# falls back to `window.location.origin`.
VITE_PUBLIC_URL=https://irontrack.vercel.app

# Resend API key for production email delivery.
# Get one at https://resend.com — leave blank to use the console fallback.
VITE_RESEND_API_KEY=
