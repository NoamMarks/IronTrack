# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Vite cache
.vite/

# Environment variables (never commit secrets) — broad match catches
# `.env`, `.env.local`, `.env.production`, `.env.staging`, etc. The
# example file is explicitly re-included so the template stays tracked.
.env
.env.*
!.env.example

# TypeScript
*.tsbuildinfo

# Python test environment
tests/.venv/
tests/__pycache__/
tests/.pytest_cache/
**/__pycache__/
**/*.pyc

# Playwright test results and traces
test-results/
playwright-report/

# OS junk
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp

.vercel

# Android signing — NEVER commit. CI decodes from base64 secret at build time.
*.jks
*.keystore
android/key.properties
android/app/google-services.json
